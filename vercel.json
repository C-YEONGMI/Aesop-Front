{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "http://aesop-env.eba-pfgz6qw2.ap-northeast-2.elasticbeanstalk.com/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
